-- ====================== LASER POINTER (Now 100% safe) ======================
local laserBeam, laserDot = nil, nil

local function createLaserPointer()
    if laserBeam then laserBeam:Destroy() end
    if laserDot then laserDot:Destroy() end

    laserBeam = Instance.new("Part")
    laserBeam.Name = "KyoshadeLaserBeam"
    laserBeam.Anchored = true
    laserBeam.CanCollide = false
    laserBeam.Transparency = 0.3
    laserBeam.Color = Color3.fromRGB(255, 0, 0)
    laserBeam.Material = Enum.Material.Neon
    laserBeam.Size = Vector3.new(0.1, 0.1, 1)
    laserBeam.Parent = Workspace

    laserDot = Instance.new("Part")
    laserDot.Name = "KyoshadeLaserDot"
    laserDot.Anchored = true
    laserDot.CanCollide = false
    laserDot.Transparency = 0.2
    laserDot.Color = Color3.fromRGB(255, 80, 80)
    laserDot.Material = Enum.Material.Neon
    laserDot.Shape = Enum.PartType.Ball
    laserDot.Size = Vector3.new(0.8, 0.8, 0.8)
    laserDot.Parent = Workspace
end

-- Safe laser update
RunService.RenderStepped:Connect(function()
    if not (inSubMenu and currentSub == "Spawn") then
        if laserBeam and laserBeam.Parent then laserBeam.Visible = false end
        if laserDot and laserDot.Parent then laserDot.Visible = false end
        return
    end

    if laserBeam and laserDot and laserBeam.Parent and laserDot.Parent then
        local origin = Camera.CFrame.Position
        local direction = (Mouse.Hit.Position - origin).Unit * 1000
        local params = RaycastParams.new()
        params.FilterDescendantsInstances = {Character}
        params.FilterType = Enum.RaycastFilterType.Exclude

        local result = Workspace:Raycast(origin, direction, params)
        if result then
            local hit = result.Position
            local dist = (hit - origin).Magnitude
            laserBeam.Size = Vector3.new(0.1, 0.1, dist)
            laserBeam.CFrame = CFrame.lookAt(origin, hit) * CFrame.new(0, 0, -dist/2)
            laserDot.Position = hit + result.Normal * 0.4

            laserBeam.Visible = true
            laserDot.Visible = true
        else
            laserBeam.Visible = false
            laserDot.Visible = false
        end
    end
end)

-- ====================== WORKING CHEATS ======================
local function updateMovement()
    if Humanoid then
        Humanoid.WalkSpeed = SubMenus.Movement[1].value
        Humanoid.JumpPower = SubMenus.Movement[4].value
    end
end

local function startFly()
    if isFlying then return end
    isFlying = true
    Humanoid.PlatformStand = true
    flyConnection = RunService.RenderStepped:Connect(function()
        if not RootPart then return end
        local move = Vector3.new()
        local cam = Workspace.CurrentCamera
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then move -= Vector3.new(0,1,0) end
        if move.Magnitude > 0 then
            RootPart.Velocity = move.Unit * SubMenus.Movement[1].value * 2.5
        else
            RootPart.Velocity = Vector3.new()
        end
    end)
end

local function stopFly()
    isFlying = false
    if flyConnection then flyConnection:Disconnect() end
    if Humanoid then Humanoid.PlatformStand = false end
end

local function startNoClip()
    if isNoclipping then return end
    isNoclipping = true
    noclipConnection = RunService.Stepped:Connect(function()
        if Character then
            for _, part in ipairs(Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
end

local function stopNoClip()
    isNoclipping = false
    if noclipConnection then noclipConnection:Disconnect() end
    if Character then
        for _, part in ipairs(Character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.CanCollide = true
            end
        end
    end
end

local function enableInfiniteJump()
    if infJumpConnection then return end
    infJumpConnection = UserInputService.JumpRequest:Connect(function()
        if Humanoid then Humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
    end)
end

local function disableInfiniteJump()
    if infJumpConnection then infJumpConnection:Disconnect() infJumpConnection = nil end
end

local function toggleGodmode(enable)
    if Humanoid then
        Humanoid.MaxHealth = enable and 1000000000 or 100
        Humanoid.Health = enable and 1000000000 or 100
    end
end

local function toggleFullBright(enable)
    Lighting.Brightness = enable and 3 or 1
    Lighting.GlobalShadows = not enable
end

local function toggleNoFog(enable)
    Lighting.FogEnd = enable and 100000 or 100
end

local function toggleESP(enable)
    for _, tag in ipairs(espTags) do tag:Destroy() end
    espTags = {}
    if not enable then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
            local bill = Instance.new("BillboardGui")
            bill.Adornee = plr.Character.Head
            bill.Size = UDim2.new(0,200,0,50)
            bill.StudsOffset = Vector3.new(0,3,0)
            bill.AlwaysOnTop = true
            bill.Parent = plr.Character.Head
            local txt = Instance.new("TextLabel", bill)
            txt.Size = UDim2.new(1,0,1,0)
            txt.BackgroundTransparency = 1
            txt.Text = plr.Name
            txt.TextColor3 = Color3.fromRGB(0,255,100)
            txt.TextStrokeTransparency = 0
            txt.Font = Enum.Font.Code
            txt.TextSize = 14
            table.insert(espTags, bill)
        end
    end
end

local function toggleSpin(enable)
    if spinConnection then spinConnection:Disconnect() spinConnection = nil end
    isSpinning = enable
    if enable and RootPart then
        spinConnection = RunService.Heartbeat:Connect(function()
            if RootPart then RootPart.AssemblyAngularVelocity = Vector3.new(0, 80, 0) end
        end)
    elseif RootPart then
        RootPart.AssemblyAngularVelocity = Vector3.new()
    end
end

-- ====================== SPAWN (Fixed & Improved) ======================
local function getAllModels()
    spawnList = {}
    for _, v in ipairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("Model") and v.PrimaryPart then table.insert(spawnList, v) end
    end
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and v.PrimaryPart and not v:FindFirstAncestor("Players") then
            table.insert(spawnList, v)
        end
    end
    print("Kyoshade: Found " .. #spawnList .. " models")
end

local function spawnModelAtMouse()
    if #spawnList == 0 then print("No models to spawn!") return end
    local model = spawnList[selectedModelIndex]
    local clone = model:Clone()
    clone.Parent = Workspace
    local pos = Mouse.Hit.Position + Vector3.new(0, 5, 0)
    clone:SetPrimaryPartCFrame(CFrame.new(pos))
    print("✅ Spawned: " .. model.Name)
end

-- ====================== UPDATE ======================
local function UpdateOverlay()
    local text = "KYOSHADE MENU\n"
    text ..= "══════════════════════════════\n\n"

    if not inSubMenu then
        for i, item in ipairs(MainMenu) do
            local prefix = (i == currentPage) and "► " or "  "
            text ..= prefix .. item.name .. "\n"
        end
    else
        text ..= currentSub:upper() .. "\n"
        text ..= "══════════════════════════════\n\n"
        local submenu = SubMenus[currentSub]
        for i, item in ipairs(submenu) do
            local prefix = (i == selectedIndex) and "► " or "  "
            local valueStr = ""
            if item.action == "toggle" then valueStr = item.value and " [ON]" or " [OFF]" end
            if item.action == "number" then valueStr = " : " .. item.value end
            text ..= prefix .. item.name .. valueStr .. "\n"
        end

        if currentSub == "Spawn" then
            local selectedName = spawnList[selectedModelIndex] and spawnList[selectedModelIndex].Name or "None"
            text ..= "\nSelected: " .. selectedName .. "\n"
            text ..= "Models (" .. #spawnList .. "):\n"
            for i, model in ipairs(spawnList) do
                local prefix = (i == selectedModelIndex) and "→ " or "  "
                text ..= prefix .. model.Name .. "\n"
            end
            text ..= "\n← → Change Model | Enter / Left Click = Spawn"
        end
    end
    Overlay.Text = text
end

-- ====================== INPUT ======================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if not inSubMenu then
        if input.KeyCode == Enum.KeyCode.Up then
            currentPage = math.max(1, currentPage - 1)
        elseif input.KeyCode == Enum.KeyCode.Down then
            currentPage = math.min(#MainMenu, currentPage + 1)
        elseif input.KeyCode == Enum.KeyCode.Return or input.KeyCode == Enum.KeyCode.KeypadEnter then
            local name = MainMenu[currentPage].name
            if name == "Remove Menu" then
                if laserBeam then laserBeam:Destroy() end
                if laserDot then laserDot:Destroy() end
                ScreenGui:Destroy()
                return
            end
            inSubMenu = true
            currentSub = name
            selectedIndex = 1
            if currentSub == "Spawn" then
                getAllModels()
                selectedModelIndex = math.max(1, math.min(selectedModelIndex, #spawnList))
            end
        end
    else
        local submenu = SubMenus[currentSub]

        if input.KeyCode == Enum.KeyCode.Up then
            selectedIndex = math.max(1, selectedIndex - 1)
        elseif input.KeyCode == Enum.KeyCode.Down then
            selectedIndex = math.min(#submenu, selectedIndex + 1)

        elseif input.KeyCode == Enum.KeyCode.Left and currentSub == "Spawn" then
            selectedModelIndex = math.max(1, selectedModelIndex - 1)
            print("← Changed to model #" .. selectedModelIndex)
        elseif input.KeyCode == Enum.KeyCode.Right and currentSub == "Spawn" then
            selectedModelIndex = math.min(#spawnList, selectedModelIndex + 1)
            print("→ Changed to model #" .. selectedModelIndex)

        elseif input.KeyCode == Enum.KeyCode.Return or input.KeyCode == Enum.KeyCode.KeypadEnter then
            local item = submenu[selectedIndex]
            if item.action == "back" then
                inSubMenu = false
                selectedIndex = currentPage
            elseif item.action == "toggle" then
                item.value = not item.value
                if currentSub == "Movement" then
                    if item.name == "Fly" then item.value and startFly() or stopFly() end
                    if item.name == "NoClip" then item.value and startNoClip() or stopNoClip() end
                elseif currentSub == "Player" then
                    if item.name == "Godmode" then toggleGodmode(item.value) end
                    if item.name == "Infinite Jump" then item.value and enableInfiniteJump() or disableInfiniteJump() end
                elseif currentSub == "Visual" then
                    if item.name == "ESP" then toggleESP(item.value) end
                    if item.name == "FullBright" then toggleFullBright(item.value) end
                    if item.name == "NoFog" then toggleNoFog(item.value) end
                elseif currentSub == "Fun" then
                    if item.name == "Spin" then toggleSpin(item.value) end
                end
            elseif item.action == "number" then
                item.value = math.min(item.max, item.value + item.step)
                if item.value < item.min then item.value = item.min end
                updateMovement()
            elseif item.action == "spawn" then
                spawnModelAtMouse()
            end
        end
    end
    UpdateOverlay()
end)

Mouse.Button1Down:Connect(function()
    if inSubMenu and currentSub == "Spawn" and #spawnList > 0 then
        spawnModelAtMouse()
    end
end)

LocalPlayer.CharacterAdded:Connect(function(newChar)
    Character = newChar
    Humanoid = newChar:WaitForChild("Humanoid")
    RootPart = newChar:WaitForChild("HumanoidRootPart")
    updateMovement()
end)

-- ====================== START ======================
createLaserPointer()
updateMovement()
UpdateOverlay()
print("Kyoshade Menu loaded - Laser pointer & Spawn selection are now fixed!")
