

loadstring([[
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RS = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Rep = game:GetService("ReplicatedStorage")
local SS = game:GetService("ServerStorage")
local WS = game:GetService("Workspace")

local LP = Players.LocalPlayer
local Mouse = LP:GetMouse()
local Cam = WS.CurrentCamera

local Char, Hum, Root
local function setupChar(c)
    Char = c
    Hum = c:WaitForChild("Humanoid", 5)
    Root = c:WaitForChild("HumanoidRootPart", 5)
end
if LP.Character then setupChar(LP.Character) end
LP.CharacterAdded:Connect(setupChar)

-- STATES
_G.Fly = false
_G.Noclip = false
_G.InfJump = false
_G.Spin = false
_G.Aimbot = false
_G.SilentAim = false
_G.ESP = false
_G.AutoClick = false
_G.Godmode = false
_G.HighJump = false
_G.Wallhack = false
_G.Fling = false

local values = {
    Speed = 70,
    JumpPower = 100,
    FlySpeed = 120,
    FOV = 80
}

local menuMode = true

-- GUI
local gui = Instance.new("ScreenGui")
gui.ResetOnSpawn = false
gui.Parent = LP:WaitForChild("PlayerGui")

local txt = Instance.new("TextLabel", gui)
txt.Size = UDim2.new(0, 560, 0, 520)
txt.Position = UDim2.new(0, 30, 0, 30)
txt.BackgroundTransparency = 1
txt.TextColor3 = Color3.fromRGB(0, 255, 160)
txt.Font = Enum.Font.Code
txt.TextSize = 17
txt.TextXAlignment = Enum.TextXAlignment.Left
txt.TextYAlignment = Enum.TextYAlignment.Top
txt.RichText = true  -- ENABLED FOR GREEN/OFF + BLUE/ON COLORS

local page = 1
local subOpen = false
local subName = ""
local sel = 1

local Main = {"Movement", "Combat", "Visual", "Fun", "Extras", "Spawn", "Settings", "Remove"}
local Sub = {
    Movement = {"Speed", "JumpPower", "FlySpeed", "FOV", "Fly", "NoClip", "Back"},
    Combat = {"Aimbot", "Silent Aim", "Back"},
    Visual = {"ESP", "Wallhack", "Back"},
    Fun = {"Spin", "Infinite Jump", "High Jump", "Fling", "Back"},
    Extras = {"Godmode", "Back"},
    Spawn = {"Spawn", "Back"},
    Settings = {"Auto Clicker", "Back"}
}

-- SPAWN SYSTEM (fixed - no collision)
local models = {}
local modelIndex = 1
local preview

local function getModels()
    models = {}
    for _, container in {Rep, SS, WS} do
        for _, v in ipairs(container:GetDescendants()) do
            if v:IsA("Model") and v.PrimaryPart then
                table.insert(models, v)
            end
        end
    end
    modelIndex = 1
end

local function makePreview()
    if preview then preview:Destroy() end
    local m = models[modelIndex]
    if not m then return end
    preview = m:Clone()
    preview.Parent = WS
    for _, p in ipairs(preview:GetDescendants()) do
        if p:IsA("BasePart") then
            p.Transparency = 0.6
            p.Material = Enum.Material.ForceField
            p.CanCollide = false
            p.Massless = true
            p.Anchored = true
        end
    end
end

local function spawnModel()
    local m = models[modelIndex]
    if not m then return end
    local c = m:Clone()
    c.Parent = WS
    if c.PrimaryPart then
        c:SetPrimaryPartCFrame(CFrame.new(Mouse.Hit.Position + Vector3.new(0, 3, 0)))
    end
end

-- ESP
local espBoxes = {}
local function updateESP()
    for _, p in Players:GetPlayers() do
        if p == LP or not p.Character then continue end
        local root = p.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        if not espBoxes[p] then
            local box = Instance.new("BoxHandleAdornment")
            box.Size = Vector3.new(4,6,2)
            box.AlwaysOnTop = true
            box.ZIndex = 10
            box.Adornee = root
            box.Parent = root
            espBoxes[p] = box
        end
        local box = espBoxes[p]
        if box and box:IsA("BoxHandleAdornment") then
            box.Visible = _G.ESP or _G.Wallhack
            box.Color3 = _G.Wallhack and Color3.fromRGB(255, 80, 80) or Color3.fromRGB(0, 255, 160)
        end
    end
end

-- Touch Fling
local hiddenfling = false
local function startFling()
    while hiddenfling do
        RS.Heartbeat:Wait()
        if Root then
            local vel = Root.Velocity
            Root.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)
            RS.RenderStepped:Wait()
            Root.Velocity = vel
            RS.Stepped:Wait()
            Root.Velocity = vel + Vector3.new(0, 0.1, 0)
        end
    end
end

-- Main Loop
RS.RenderStepped:Connect(function()
    if preview and preview.PrimaryPart and subOpen and subName == "Spawn" then
        preview:SetPrimaryPartCFrame(CFrame.new(Mouse.Hit.Position + Vector3.new(0, 2, 0)))
    end

    if _G.Fly and Root then
        local bv = Root:FindFirstChild("BV") or Instance.new("BodyVelocity", Root)
        bv.Name = "BV"
        bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        local move = Vector3.zero
        if UIS:IsKeyDown(Enum.KeyCode.W) then move += Cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then move -= Cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then move -= Cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then move += Cam.CFrame.RightVector end
        bv.Velocity = move * values.FlySpeed
    elseif Root and Root:FindFirstChild("BV") then
        Root.BV:Destroy()
    end

    if _G.Noclip and Char then
        for _, v in ipairs(Char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = false
            end
        end
    end

    if _G.Spin and Root then
        Root.CFrame *= CFrame.Angles(0, math.rad(8), 0)
    end

    if _G.Aimbot then
        local target = nil
        local dist = math.huge
        for _, p in Players:GetPlayers() do
            if p ~= LP and p.Character and p.Character:FindFirstChild("Head") then
                local pos, onscreen = Cam:WorldToViewportPoint(p.Character.Head.Position)
                if onscreen then
                    local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if d < dist then dist = d target = p.Character.Head end
                end
            end
        end
        if target then
            Cam.CFrame = CFrame.new(Cam.CFrame.Position, target.Position)
        end
    end

    if _G.AutoClick then mouse1click() end
    updateESP()

    Cam.FieldOfView = values.FOV

    if _G.Godmode and Hum then
        Hum.MaxHealth = 99999
        Hum.Health = 99999
    end

    if _G.HighJump and Hum then
        Hum.JumpPower = values.JumpPower + 60
    end
end)

UIS.JumpRequest:Connect(function()
    if _G.InfJump and Hum then
        Hum:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)

-- Menu Draw (NO BOOL TEXT → GREEN if OFF, BLUE if ON)
local function draw()
    local modeText = menuMode and " [MENU MODE: ON]" or " [MENU MODE: OFF - Press Z]"
    local t = "   KYOSHADE MENU" .. modeText .. "\n\n"
    
    if not subOpen then
        for i, v in ipairs(Main) do
            t ..= (i == page and " ► " or "   ") .. v .. "\n"
        end
    else
        t ..= "   " .. subName .. "\n\n"
        for i, v in ipairs(Sub[subName] or {}) do
            local val = (v == "Speed" or v == "JumpPower" or v == "FlySpeed" or v == "FOV") and values[v] or
                        (v == "Fly" and _G.Fly) or (v == "NoClip" and _G.Noclip) or (v == "Spin" and _G.Spin) or
                        (v == "Infinite Jump" and _G.InfJump) or (v == "High Jump" and _G.HighJump) or
                        (v == "Fling" and _G.Fling) or (v == "Aimbot" and _G.Aimbot) or (v == "Silent Aim" and _G.SilentAim) or
                        (v == "ESP" and _G.ESP) or (v == "Wallhack" and _G.Wallhack) or (v == "Godmode" and _G.Godmode) or
                        (v == "Auto Clicker" and _G.AutoClick)
            
            local prefix = (i == sel and " ► " or "   ")
            local colorTag = ""
            local extra = ""
            
            if val ~= nil then
                if type(val) == "boolean" then
                    -- TOGGLE: color only the name (green = OFF, blue = ON), no [true/false]
                    local col = val and "#0000FF" or "#00FF00"
                    colorTag = '<font color="' .. col .. '">'
                    extra = "</font>"
                else
                    -- SLIDER: keep number in brackets, default color
                    extra = " [" .. tostring(val) .. "]"
                end
            end
            
            t ..= prefix .. colorTag .. v .. extra .. "\n"
        end
        if subName == "Spawn" then
            t ..= "\n   Current: " .. (models[modelIndex] and models[modelIndex].Name or "None") .. " (" .. modelIndex .. "/" .. #models .. ")"
        end
    end
    txt.Text = t
end

-- Input (MENU KEY = Z)
UIS.InputBegan:Connect(function(i, g)
    if g then return end

    if i.KeyCode == Enum.KeyCode.Z then
        menuMode = not menuMode
        draw()
        return
    end

    if not menuMode then return end

    if not subOpen then
        if i.KeyCode == Enum.KeyCode.W then page = math.max(1, page-1)
        elseif i.KeyCode == Enum.KeyCode.S then page = math.min(#Main, page+1)
        elseif i.KeyCode == Enum.KeyCode.E then
            if Main[page] == "Remove" then gui:Destroy() return end
            subOpen = true
            subName = Main[page]
            sel = 1
            if subName == "Spawn" then
                getModels()
                makePreview()
            end
        end
    else
        if i.KeyCode == Enum.KeyCode.W then sel = math.max(1, sel-1)
        elseif i.KeyCode == Enum.KeyCode.S then sel = math.min(#Sub[subName], sel+1)
        elseif i.KeyCode == Enum.KeyCode.A then
            local item = Sub[subName][sel]
            if item == "Speed" then values.Speed = math.max(16, values.Speed - 10)
            elseif item == "JumpPower" then values.JumpPower = math.max(0, values.JumpPower - 10)
            elseif item == "FlySpeed" then values.FlySpeed = math.max(50, values.FlySpeed - 10)
            elseif item == "FOV" then values.FOV = math.max(50, values.FOV - 5) end
        elseif i.KeyCode == Enum.KeyCode.D then
            local item = Sub[subName][sel]
            if item == "Speed" then values.Speed += 10
            elseif item == "JumpPower" then values.JumpPower += 10
            elseif item == "FlySpeed" then values.FlySpeed += 10
            elseif item == "FOV" then values.FOV = math.min(120, values.FOV + 5) end
        elseif i.KeyCode == Enum.KeyCode.E then
            local item = Sub[subName][sel]
            if item == "Back" then
                subOpen = false
                if preview then preview:Destroy() preview = nil end
            elseif item == "Spawn" then
                spawnModel()
            else
                local key = item == "Silent Aim" and "SilentAim" or item == "Infinite Jump" and "InfJump" or item == "High Jump" and "HighJump" or item == "Fling" and "Fling" or item == "Auto Clicker" and "AutoClick" or item
                if _G[key] ~= nil then
                    _G[key] = not _G[key]
                    if key == "Fling" then
                        hiddenfling = _G.Fling
                        if hiddenfling then
                            spawn(startFling)
                        end
                    end
                end
            end
        end

        if subName == "Spawn" then
            if i.KeyCode == Enum.KeyCode.One then
                modelIndex = math.max(1, modelIndex - 1)
                makePreview()
            elseif i.KeyCode == Enum.KeyCode.Two then
                modelIndex = math.min(#models, modelIndex + 1)
                makePreview()
            end
        end
    end

    if Hum then
        Hum.WalkSpeed = values.Speed
        if not _G.HighJump then Hum.JumpPower = values.JumpPower end
    end
    draw()
end)

Mouse.Button1Down:Connect(function()
    if subOpen and subName == "Spawn" then
        spawnModel()
    end
end)

-- Lighting
Lighting.Brightness = 2
Lighting.ClockTime = 14
Lighting.FogEnd = 100000

draw()
print("🔥 KYOSHADE v7 LOADED pookie ❤️")
print("Menu key is now Z")
print("Toggles are GREEN when OFF and BLUE when ON (no more [bool])")
print("Spawn preview should no longer push back")
print("Noclip improved | Fling uses the strong touch fling")
print("Press Z to toggle Menu Mode | 1/2 to change models in Spawn")
]])() 
