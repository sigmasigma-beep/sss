-- Menu & Spawn State
local currentPage = 1
local inSubMenu = false
local currentSub = ""
local selectedIndex = 1
local spawnList = {}
local selectedModelIndex = 1

-- Cheat state
local flyConnection, noclipConnection, infJumpConnection, spinConnection = nil, nil, nil, nil
local isFlying, isNoclipping, isSpinning = false, false, false
local espTags = {}

